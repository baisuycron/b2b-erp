# Frontend build/runtime
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# Backend runtime
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:mysql://127.0.0.1:3306/b2b_erp?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Shanghai
DB_USERNAME=b2b_erp
DB_PASSWORD=change_me

# Reserved placeholders for deployment consistency.
# The current Java backend code does not consume these variables yet.
JWT_SECRET=replace_with_a_long_random_string
CORS_ALLOWED_ORIGIN=http://127.0.0.1:5173
UPLOAD_DIR=/data/b2b-erp/uploads
JAVA_OPTS=-Xms512m -Xmx1024m

# Image search
IMAGE_SEARCH_ENABLED=true
IMAGE_EMBEDDING_SERVICE_URL=http://127.0.0.1:8080/api/internal/image-embedding
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
IMAGE_VECTOR_COLLECTION=product-images
IMAGE_SEARCH_TOP_K_DEFAULT=20
IMAGE_SEARCH_MINIMUM_SCORE=0.72
IMAGE_EMBEDDING_MODEL=b2b-visual-signature-v2
